# Database
POSTGRES_DB=autoai
POSTGRES_USER=autoai
POSTGRES_PASSWORD=your_secure_password
DATABASE_URL=postgresql+asyncpg://autoai:your_secure_password@postgres:5432/autoai

# Redis
REDIS_URL=redis://redis:6379/0

# App
DEBUG=false
APP_NAME=AutoAI

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# API Security
API_KEY=your-secret-api-key

# YandexGPT (опционально)
YANDEX_GPT_API_KEY=
