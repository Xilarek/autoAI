# Database
POSTGRES_DB=autoai
POSTGRES_USER=autoai
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql+asyncpg://autoai:your_secure_password_here@postgres:5432/autoai

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# YandexGPT
YANDEX_GPT_API_KEY=your-yandex-gpt-api-key
YC_FOLDER_ID=your-yandex-cloud-folder-id

# App
APP_NAME=AutoAI
DEBUG=True
